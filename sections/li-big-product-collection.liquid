{% assign big_product_handle = collection.metafields.custom.big_product %}
{% assign big_product = null %}
{% assign small_products = '' %}

{% for product in collection.products %}
  {% if big_product == null and product.handle == big_product_handle %}
    {% assign big_product = product %}
  {% else %}
    {% assign small_products = small_products | append: product.handle | append: ',' %}
  {% endif %}
{% endfor %}

{% assign small_products = small_products | split: ',' | slice: 0, 5 %}

<div class="collection">
  {% if big_product != blank %}
    <div class="collection__item collection__item--big">
      <a href="{{ big_product.url }}">
        <img src="{{ big_product.featured_image | img_url: 'large' }}" alt="{{ big_product.title }}">
        <h3>{{ big_product.title }}</h3>
      </a>
    </div>
  {% endif %}

  <div class="collection__items">
    {% for handle in small_products %}
      {% assign product = all_products[handle] %}
      {% if product != blank %}
        <div class="collection__item collection__item--small">
          <a href="{{ product.url }}">
            <img src="{{ product.featured_image | img_url: 'medium' }}" alt="{{ product.title }}">
            <h3>{{ product.title }}</h3>
          </a>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</div>

{% style %}
  .collection {
    display: flex;
    flex-wrap: wrap;
  }

  .collection__item {
    box-sizing: border-box;
    padding: 10px;
  }

  .collection__item--big {
    width: 100%;
    order: 1;
  }

  .collection__item--small {
    width: 25%;
  }

  @media (max-width: 767px) {
    .collection__item--small {
      width: 50%;
    }
  }

  .collection__item--big img,
  .collection__item--small img {
    width: 100%;
    height: auto;
  }

  .collection__item h3 {
    text-align: center;
    margin-top: 10px;
  }
{% endstyle %}


{% schema %}
{
  "name": "Custom Collection",
  "settings": [
    {
      "type": "product",
      "id": "big_product",
      "label": "Big Product"
    }
  ],
  "presets": [
    {
      "name": "Custom Collection",
      "category": "Collections"
    }
  ]
}
{% endschema %}